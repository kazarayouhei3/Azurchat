              <property name="styleSheet">
               <string notr="true">QLineEdit {
    background-color: white;
    border-radius: 11px;
    padding: 5px;
}

/* 鼠标放上去 */
QLineEdit:hover {
    background-color: #F2F4F7;  /* 稍微变深一点 */
}

/* 获取焦点（点击后） */
QLineEdit:focus {
    background-color: #EEF1F5;  /* 再深一点，更有层次 */
}</string>
