              <property name="styleSheet">
               <string notr="true">QPushButton#loginButton{
    background-color: #3B82F6;  /* 默认 */
    color: white;
    border-radius: 10px;
    padding: 5px;
    border: none;
}

/* 悬停（稍微亮一点） */
QPushButton#loginButton:hover {
    background-color: #5A9BFF;
}

/* 按下（稍微暗一点，有“压下去”的感觉） */
QPushButton#loginButton:pressed {
    background-color: #2563EB;
}</string>
