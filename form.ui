              <property name="styleSheet">
               <string notr="true">QToolButton {
    border: none;
    color: #666;
    padding: 5px;
    qproperty-iconSize: 20px 20px;
}

/* ❌ hover 不再改背景 */
QToolButton:hover {
    color: #1677FF;   /* ⭐只改文字颜色 */
}

/* ✅ 选中才改背景 */
QToolButton:checked {
    background-color: #EBF3FF;
    color: #1677FF;
    border-bottom-left-radius: 20px;
    border-bottom-right-radius: 20px;
}</string>
